# =============================================================================
# Creditra Backend — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED
# -----------------------------------------------------------------------------

# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Docker Compose host default: postgresql://postgres:postgres@localhost:5432/creditra_db
# The api container overrides this to use the compose service host `db`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/creditra_db

# Comma-separated list of API keys for authenticating admin requests.
# Sent by clients in the X-Api-Key header (at least one key required).
# Rotation: add new key alongside old key → deploy → update clients → remove old key.
# Local-only placeholder. Replace before using shared or deployed environments.
API_KEYS=dev-api-key

# -----------------------------------------------------------------------------
# OPTIONAL — server
# -----------------------------------------------------------------------------

# HTTP port the server binds to. Default: 3000
# PORT=3000

# Node environment. Allowed values: development | production | test
# Controls CORS fallback behaviour.
# Default: development
# NODE_ENV=development

# -----------------------------------------------------------------------------
# OPTIONAL — rate limiting
# -----------------------------------------------------------------------------

# Per-route fixed-window limits.
# Defaults: 60000 ms window, 100 generic requests, 10 risk evaluations.
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_MAX_EVALUATE=10

# Redis URL for rate-limit counters shared across horizontally scaled replicas.
# Leave unset to use the in-process store.
# RATE_LIMIT_REDIS_URL=redis://localhost:6379

# Redis outage policy for rate limiting. Allowed values: open | closed
# Default: open (requests continue instead of returning 500 when Redis is down).
# RATE_LIMIT_REDIS_FAILURE_MODE=open

# Graceful shutdown timeout in milliseconds.
# The server waits this long for in-flight requests after SIGTERM/SIGINT.
# Default: 30000
# SHUTDOWN_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# OPTIONAL — CORS (required in production)
# -----------------------------------------------------------------------------

# Comma-separated allowlist of exact browser origins permitted to send
# cross-origin requests. Required when NODE_ENV=production.
# Non-production environments fall back to loopback origins automatically.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ORIGINS=

# -----------------------------------------------------------------------------
# OPTIONAL — Stellar Horizon listener
# -----------------------------------------------------------------------------

# Stellar Horizon API base URL.
# Default: https://horizon-testnet.stellar.org (testnet)
# Use https://horizon.stellar.org for mainnet.
# HORIZON_URL=https://horizon-testnet.stellar.org

# Comma-separated list of Soroban contract IDs to watch for events.
# Leave empty to run without contract event polling.
# CONTRACT_IDS=

# Horizon polling interval in milliseconds. Minimum: 100. Default: 5000
# POLL_INTERVAL_MS=5000

# Ledger sequence number to begin replaying events from.
# Use "latest" to start from now (ignore historical events).
# HORIZON_START_LEDGER=latest

# -----------------------------------------------------------------------------
# OPTIONAL — Admin endpoints
# -----------------------------------------------------------------------------

# API key for admin-only endpoints (X-Admin-Api-Key header).
# When unset, admin endpoints respond 503 Service Unavailable.
# ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# OPTIONAL — Data retention (see docs/DATA_RETENTION.md)
# -----------------------------------------------------------------------------

# Set to "false" to disable the scheduled retention sweep entirely.
# No-op when running without DATABASE_URL (in-memory mode). Default: true
# DATA_RETENTION_ENABLED=true

# How often the retention sweep runs, in milliseconds. Default: 86400000 (24h)
# DATA_RETENTION_INTERVAL_MS=86400000

# Set to "true" to run a sweep immediately on boot, in addition to the
# scheduled interval. Default: false
# DATA_RETENTION_RUN_IMMEDIATELY=false

# Days of inactivity before a borrower's risk evaluations are purged and
# their wallet_address is anonymized (only for borrowers with no active
# credit line). Default: 90
# DATA_RETENTION_OPERATIONAL_DAYS=90

# Days before immutable `events` audit rows are purged. Default: 365
# DATA_RETENTION_EVENTS_DAYS=365
